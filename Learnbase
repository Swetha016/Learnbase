<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LMS Output Screens</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#f2f2f2;
      padding:20px;
    }

    .page{
      width:90%;
      margin:30px auto;
      background:white;
      padding:20px;
      border:2px solid #000;
    }

    h2{
      margin-bottom:15px;
      color:#222;
    }

    /* LOGIN PAGE */
    .login-section{
      height:500px;
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(to right,#ff9ad5,#ff5f8f);
    }

    .login-box{
      width:320px;
      background:white;
      padding:25px;
      border-radius:10px;
      box-shadow:0 0 10px rgba(0,0,0,0.2);
      text-align:center;
    }

    .login-box h1{
      color:#ff4f87;
      margin-bottom:15px;
    }

    .login-box input{
      width:100%;
      padding:10px;
      margin:8px 0;
      border:1px solid #ccc;
      border-radius:5px;
    }

    .btn{
      width:100%;
      padding:10px;
      border:none;
      background:#ff5f8f;
      color:white;
      border-radius:5px;
      cursor:pointer;
      margin-top:10px;
    }

    /* HOME PAGE */
    .navbar{
      background:#0066ff;
      color:white;
      padding:12px;
      font-size:20px;
    }

    .dashboard{
      padding:20px;
    }

    .cards{
      display:flex;
      gap:20px;
      margin-top:20px;
      flex-wrap:wrap;
    }

    .card{
      flex:1;
      min-width:150px;
      background:#eaf3ff;
      padding:20px;
      border-radius:8px;
      text-align:center;
      border:1px solid #bcd7ff;
    }

    /* COURSE PAGE */
    .course-box{
      display:flex;
      gap:20px;
      flex-wrap:wrap;
    }

    .sidebar{
      width:200px;
      background:#f0f0f0;
      padding:15px;
      border-radius:8px;
    }

    .sidebar ul{
      list-style:none;
    }

    .sidebar li{
      padding:10px;
      margin:8px 0;
      background:#fff;
      border-radius:5px;
      border:1px solid #ddd;
    }

    .course-content{
      flex:1;
      background:#fafafa;
      padding:15px;
      border-radius:8px;
      border:1px solid #ddd;
    }

    .course-content img{
      width:100%;
      border-radius:10px;
      margin-top:10px;
    }

    /* QUIZ */
    .quiz-box{
      background:#fff;
      padding:20px;
      border-radius:10px;
      border:1px solid #ccc;
      width:80%;
      margin:auto;
    }

    .question{
      font-size:20px;
      margin-bottom:15px;
    }

    .option{
      background:#f5f5f5;
      padding:12px;
      margin:10px 0;
      border-radius:5px;
      cursor:pointer;
      border:1px solid #ddd;
    }

    .option:hover{
      background:#dfefff;
    }

    .result-box{
      margin-top:20px;
      font-size:22px;
      color:green;
      text-align:center;
      display:none;
    }

    /* RESULT PAGE */
    .result-page{
      padding:20px;
      font-size:20px;
      line-height:1.8;
    }

    @media(max-width:768px){
      .course-box{
        flex-direction:column;
      }

      .sidebar{
        width:100%;
      }

      .quiz-box{
        width:100%;
      }
    }
  </style>
</head>
<body>

  <!-- PAGE 1 LOGIN -->
  <div class="page">
    <h2>Student Sign Up</h2>

    <div class="login-section">
      <div class="login-box">
        <h1>LearnBase</h1>

        <input type="text" placeholder="First Name">
        <input type="text" placeholder="Last Name">
        <input type="email" placeholder="Email Address">
        <input type="password" placeholder="Password">
        <input type="password" placeholder="Confirm Password">

        <button class="btn">Create Student Account</button>
      </div>
    </div>
  </div>


  <!-- PAGE 2 HOME -->
  <div class="page">
    <h2>Home Page</h2>

    <div class="navbar">LearnBase LMS</div>

    <div class="dashboard">
      <h1>Welcome Back, Arun!</h1>

      <div class="cards">
        <div class="card">
          <h3>Courses</h3>
          <p>5</p>
        </div>

        <div class="card">
          <h3>Completed</h3>
          <p>2</p>
        </div>

        <div class="card">
          <h3>Pending</h3>
          <p>3</p>
        </div>

        <div class="card">
          <h3>Quiz</h3>
          <p>1</p>
        </div>
      </div>
    </div>
  </div>


  <!-- PAGE 3 COURSE MODULE -->
  <div class="page">
    <h2>Course Module</h2>

    <div class="course-box">

      <div class="sidebar">
        <ul>
          <li>HTML</li>
          <li>CSS</li>
          <li>JavaScript</li>
          <li>React</li>
        </ul>
      </div>

      <div class="course-content">
        <h2>HTML Course</h2>

        <img src="https://i.ytimg.com/vi/qz0aGYrrlhU/maxresdefault.jpg" alt="HTML Course">
      </div>

    </div>
  </div>


  <!-- PAGE 4 QUIZ -->
  <div class="page">
    <h2>Quiz</h2>

    <div class="quiz-box">
      <div class="question">
        Q1. What does HTML stand for?
      </div>

      <div class="option" onclick="checkAnswer(true)">
        Hyper Text Markup Language
      </div>

      <div class="option" onclick="checkAnswer(false)">
        High Text Modern Language
      </div>

      <div class="option" onclick="checkAnswer(false)">
        Home Tool Markup Language
      </div>

      <div class="option" onclick="checkAnswer(false)">
        Hyperlinks and Text Markup Language
      </div>

      <div class="result-box" id="result"></div>
    </div>
  </div>


  <!-- PAGE 5 RESULT -->
  <div class="page">
    <h2>Result</h2>

    <div class="result-page">
      The Learning Management System was successfully designed and implemented.
      The system allows instructors to upload courses and manage content,
      while students can enroll, access materials, and complete quizzes efficiently.
    </div>
  </div>


  <script>
    function checkAnswer(correct){
      let result=document.getElementById("result");

      if(correct){
        result.style.display="block";
        result.innerHTML="✅ Correct Answer";
      }
      else{
        result.style.display="block";
        result.innerHTML="❌ Wrong Answer";
        result.style.color="red";
      }
    }
  </script>

</body>
</html>
